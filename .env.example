# Seestar S50 hardware
SEESTAR_IP=192.168.4.1
SEESTAR_PORT=11111

# Timezone
TZ=America/New_York

# Portal UI → Backend URL (override if running backend on a different host/port)
BACKEND_URL=http://seestar-portal-backend:8503

# Cloudflare tunnel token — only required when running with --profile tunnel
# (Jetson remote deployment). Generate via Cloudflare Zero Trust dashboard:
# Networks → Tunnels → Create a tunnel → copy the token.
# Configure ingress in the dashboard: <hostname> → http://seestar-portal-ui:8502
CLOUDFLARE_TUNNEL_TOKEN=
