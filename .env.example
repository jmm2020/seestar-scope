# Seestar S50 hardware
SEESTAR_IP=192.168.4.1
SEESTAR_PORT=11111

# Timezone
TZ=America/New_York

# Portal UI → Backend URL (override if running backend on a different host/port)
BACKEND_URL=http://seestar-portal-backend:8503

# Cloudflare tunnel — file-based config. No env vars required here.
# When running with --profile tunnel, populate ./cloudflared/ with:
#   - config.yml          (committed template; edit ingress to your hostname)
#   - <tunnel-id>.json    (credentials, gitignored, copied from workstation)
# See deploy/jetson/README.md → Remote Access for the full procedure.
