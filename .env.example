# Seestar S50 hardware
# Station mode (Seestar joined home WiFi, most common): SEESTAR_IP=192.168.0.132
# AP mode (host joined Seestar's own WiFi hotspot):     SEESTAR_IP=192.168.4.1
# Port 32323 is correct for ALPACA in both modes.
SEESTAR_IP=192.168.0.132
SEESTAR_PORT=32323

# Timezone
TZ=America/New_York

# Portal UI → seestar_alp bridge (ALP = ALPACA Local Proxy)
# These must match the service name and port in docker-compose.yml.
# Legacy names SEESTAR_ALP_HOST / SEESTAR_ALP_PORT / SEESTAR_IMG_PORT are also
# accepted as fallbacks to avoid breaking existing deploys.
ALP_HOST=seestar-alp
ALP_PORT=5555
# ALP_IMG_PORT=7556   # only needed if img port differs from the default

# Portal UI → Backend URL (override if running backend on a different host/port)
BACKEND_URL=http://seestar-portal-backend:8503

# Stellarium integration (optional)
# Set STELLARIUM_HOST if Stellarium runs on a different machine than the portal host
# STELLARIUM_HOST=192.168.0.36
# STELLARIUM_PORT=8090

# Cloudflare tunnel — file-based config. No env vars required here.
# When running with --profile tunnel, populate ./cloudflared/ with:
#   - config.yml          (committed template; edit ingress to your hostname)
#   - <tunnel-id>.json    (credentials, gitignored, copied from workstation)
# See deploy/jetson/README.md → Remote Access for the full procedure.

# Siril stacking pipeline (portal backend)
# SIRIL_BIN: path or command for siril-cli.
#   Default: siril-cli (works on x86_64 + Ubuntu 22.04 aarch64 via apt).
#   ARM64/Flatpak override: SIRIL_BIN="flatpak run --command=siril-cli org.siril.Siril"
#   Note: the lock042/siril PPA has a broken ARM64 build as of early 2026 — do not use it.
# SIRIL_TIMEOUT: asyncio timeout in seconds for the siril-cli subprocess (default: 600).
# SIRIL_BIN=siril-cli
# SIRIL_TIMEOUT=600
