# Seestar S50 — Jetson Orin defaults
SEESTAR_IP=192.168.0.132
SEESTAR_PORT=32323
TZ=America/New_York
# Portal UI → Backend (docker bridge DNS — do not change unless running backend externally)
BACKEND_URL=http://seestar-portal-backend:8503

# Stellarium integration (optional)
# Set STELLARIUM_HOST if Stellarium runs on a different machine than the Jetson host
# STELLARIUM_HOST=192.168.0.36
# STELLARIUM_PORT=8090

# Observing site (overrides config.toml [site] section)
# SITE_LAT=37.12
# SITE_LON=-123.45
# SITE_ELEVATION_M=0.0
# SITE_NAME="My Observatory"

# Auth + Billing (Phase 5a — Supabase + Stripe)
# Provision: see docs/auth-billing-setup.md
# SUPABASE_URL=https://<project-ref>.supabase.co
# SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=
# SUPABASE_JWT_SECRET=
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_WATCH_PRICE_ID=price_...
# STRIPE_CONTROL_PRICE_ID=price_...
